{
  "name": "melunai",
  "version": "0.1.0",
  "description": "Local-first AI workspace powered by local LLMs.",
  "license": "MIT",
  "author": "Melunai contributors",
  "type": "module",
  "main": "dist-electron/main/main.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "npm run test:unit",
    "test:build": "tsc -p tsconfig.test.json",
    "test:unit": "npm run test:build && node --test dist-test/tests/unit/**/*.test.js dist-test/tests/unit/*.test.js",
    "test:corpus": "tsc -p tsconfig.test-corpus.json && node --test dist-test-corpus/tests/unit/corpus/corpusPrompt.test.js",
    "typecheck": "tsc --noEmit",
    "electron:build": "node scripts/setup-electron.mjs && tsc -p tsconfig.electron.json",
    "electron:dev": "concurrently -k -n VITE,ELECTRON \"vite\" \"wait-on http://localhost:1420 && npm run electron:build && electron .\"",
    "electron:dist": "npm run electron:pack",
    "electron:pack": "npm run build && npm run electron:build && electron-builder"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.0.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.5.0",
    "vite": "^8.0.11",
    "wait-on": "^9.0.6"
  }
}
